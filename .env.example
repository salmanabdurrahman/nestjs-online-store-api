# Runtime
NODE_ENV=development
PORT=3000

# Database
# Replace with local PostgreSQL connection string during Prisma setup.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_online_store?schema=public
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/nestjs_online_store_test?schema=public

# Auth
# Use a strong secret in local .env. Do not commit real secrets.
JWT_SECRET=change-me-in-local-env
JWT_ACCESS_EXPIRES_IN=15m

# CORS
# Comma-separated allowed origins. Empty means same-origin/local defaults until config is implemented.
CORS_ORIGINS=http://localhost:3000
